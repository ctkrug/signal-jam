{
  "name": "signal-jam-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web shell (Canvas waterfall renderer + UI) for Signal Jam",
  "scripts": {
    "build:wasm": "cd ../crate && cargo build --release --target wasm32-unknown-unknown && wasm-bindgen --target web --out-dir ../web/src/wasm target/wasm32-unknown-unknown/release/signal_jam_core.wasm",
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.9.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
